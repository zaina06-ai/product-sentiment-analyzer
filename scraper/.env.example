# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your own values.
# Never commit your real ".env" file to git.
# ---------------------------------------------------------------------------

# MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://yadhra:yadhra2006@cluster0.arzrudl.mongodb.net/?appName=Cluster0


# Optional overrides (sensible defaults are used if omitted)
MONGO_DB_NAME=product_sentiment
MONGO_COLLECTION_NAME=reviews

# Set to False to watch the browser while it scrapes (useful for debugging)
HEADLESS=True

# Max seconds to wait for a page element before timing out
EXPLICIT_WAIT_TIMEOUT=15

# Max retry attempts for transient Selenium failures
MAX_RETRIES=3

# Safety cap on number of review pagination pages (not a review limit)
MAX_REVIEW_PAGES=5000
