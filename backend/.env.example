# Copy this file to .env and fill in your MongoDB connection string.
# If you don't set this up at all, the app still works — it just
# scrapes fresh every time instead of caching results.

# Local MongoDB (if you installed MongoDB Community Server):
# MONGODB_URI=mongodb://localhost:27017

# MongoDB Atlas (free cloud tier, no install needed):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=sentiscrap
